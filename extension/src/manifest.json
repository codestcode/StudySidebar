{
  "manifest_version": 3,
  "name": "StudySidebar",
  "version": "1.0.0",
  "description": "AI-powered study assistant for CS students",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "StudySidebar",
    "default_icon": {
      "16": "images/Logo-vecotor.png",
      "48": "images/Logo-vecotor.png",
      "128": "images/Logo-vecotor.png"
    }
  },
  "icons": {
    "16": "images/Logo-vecotor.png",
    "48": "images/Logo-vecotor.png",
    "128": "images/Logo-vecotor.png"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; img-src 'self' https://res.cloudinary.com; connect-src 'self' http://localhost:3001; style-src 'self' 'unsafe-inline'"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
